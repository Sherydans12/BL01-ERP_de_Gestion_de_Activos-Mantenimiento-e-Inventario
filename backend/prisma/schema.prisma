generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// 1. MAESTRO DE FLOTA (EQUIPMENT)
// ==========================================
model Equipment {
  id                      String    @id @default(uuid()) @db.Uuid
  tenantId                String    @map("tenant_id") @db.Uuid
  siteId                  String?   @map("site_id") @db.Uuid
  internalId              String    @map("internal_id") @db.VarChar(50) // Ej: EC-3005
  plate                   String?   @db.VarChar(20) // Ej: VCJW-21 (Bulls pueden no tener)
  type                    String    @db.VarChar(50) // Ej: CAMIONETA, BULLDOZER
  brand                   String    @db.VarChar(50) // Ej: TOYOTA, CAT
  model                   String    @db.VarChar(50) // Ej: HILUX
  initialHorometer        Int       @default(0) @map("initial_horometer")
  currentHorometer        Int       @default(0) @map("current_horometer")
  
  // Identificación Extendida
  vin                     String?   @db.VarChar(50)
  engineNumber            String?   @map("engine_number") @db.VarChar(50)
  year                    Int?

  // Operación y Mantenimiento
  fuelType                String?   @map("fuel_type") @db.VarChar(50)
  driveType               String?   @map("drive_type") @db.VarChar(50)
  ownership               String?   @db.VarChar(50)
  maintenanceFrequency    Int?      @map("maintenance_frequency")
  
  // Vencimientos Legales
  techReviewExp           DateTime? @map("tech_review_exp") @db.Date
  circPermitExp           DateTime? @map("circ_permit_exp") @db.Date

  // Auditoría
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  // Relaciones
  tenant                  Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  site            Site?     @relation(fields: [siteId], references: [id], onDelete: SetNull)
  workOrders              WorkOrder[]

  @@unique([tenantId, internalId])
  @@unique([tenantId, plate])
  @@unique([tenantId, vin])
  @@map("equipments")
}

// ==========================================
// 2. CATÁLOGOS GLOBALES (SYSTEMS, FLUIDS)
// ==========================================
model CatalogItem {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  code        String   @db.VarChar(20) // Ej: SYS-01, FLD-01
  name        String   @db.VarChar(100)
  category    CatalogCategory
  isActive    Boolean  @default(true) @map("is_active")

  // Relaciones
  tenant              Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  systemInterventions WorkOrderSystem[]
  fluidConsumptions   WorkOrderFluid[]

  @@unique([tenantId, code])
  @@map("catalog_items")
}

enum CatalogCategory {
  EQUIPMENT_TYPE
  BRAND
  SYSTEM
  FLUID
  FUEL_TYPE
  DRIVE_TYPE
  OWNERSHIP
}

// ==========================================
// 3. ÓRDENES DE TRABAJO (OT)
// ==========================================
model WorkOrder {
  id                String    @id @default(uuid()) @db.Uuid
  tenantId          String    @map("tenant_id") @db.Uuid
  siteId          String?   @map("site_id") @db.Uuid
  correlative       String    @db.VarChar(30) // Ej: OT-2026-001
  equipmentId       String    @map("equipment_id") @db.Uuid
  type              OtType    @default(NUEVA)
  category          OtCategory
  maintenanceType   MaintenanceType @map("maintenance_type") // PREVENTIVO o CORRECTIVO
  status            OtStatus  @default(OPEN)
  
  initialHorometer  Int       @map("initial_horometer")
  finalHorometer    Int       @map("final_horometer")
  description       String    @db.Text
  
  hasBacklog        Boolean   @default(false) @map("has_backlog")

  // Auditoría (Para soportar Sync Offline después)
  createdAt         DateTime  @default(now()) @map("created_at")
  syncedAt          DateTime? @map("synced_at")
  closedAt          DateTime? @map("closed_at")

  // Relaciones
  tenant            Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  site              Site?             @relation(fields: [siteId], references: [id], onDelete: SetNull)
  equipment         Equipment         @relation(fields: [equipmentId], references: [id])
  systems           WorkOrderSystem[]
  fluids            WorkOrderFluid[]

  @@unique([tenantId, correlative])
  @@map("work_orders")
}

enum OtType {
  NUEVA
  CONTINUIDAD
}

enum OtCategory {
  PROGRAMADA
  NO_PROGRAMADA
  ACCIDENTE
}

enum MaintenanceType {
  PREVENTIVO
  CORRECTIVO
}

enum OtStatus {
  OPEN
  IN_PROGRESS
  ON_HOLD
  CLOSED
}

// ==========================================
// 4. TABLAS INTERMEDIAS (RELACIONES M:N)
// ==========================================
model WorkOrderSystem {
  workOrderId   String @map("work_order_id") @db.Uuid
  catalogItemId String @map("catalog_item_id") @db.Uuid

  workOrder     WorkOrder   @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  catalogItem   CatalogItem @relation(fields: [catalogItemId], references: [id], onDelete: Restrict)

  @@id([workOrderId, catalogItemId])
  @@map("work_order_systems")
}

model WorkOrderFluid {
  id            String @id @default(uuid()) @db.Uuid
  workOrderId   String @map("work_order_id") @db.Uuid
  catalogItemId String @map("catalog_item_id") @db.Uuid
  
  liters        Float
  action        FluidAction

  workOrder     WorkOrder   @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  catalogItem   CatalogItem @relation(fields: [catalogItemId], references: [id], onDelete: Restrict)

  @@map("work_order_fluids")
}

enum FluidAction {
  RELLENO
  CAMBIO
}

// ==========================================
// 5. USUARIOS Y AUTENTICACIÓN
// ==========================================
model User {
  id              String    @id @default(uuid()) @db.Uuid
  email           String    @unique @db.VarChar(100)
  password        String    @db.VarChar(255)
  name            String    @db.VarChar(100)
  role            UserRole  @default(MECHANIC)
  isActive        Boolean   @default(false) @map("is_active")
  activationToken String?   @map("activation_token") @db.VarChar(255)
  resetPasswordToken   String?   @map("reset_password_token") @db.VarChar(255)
  resetPasswordExpires DateTime? @map("reset_password_expires")
  
  // Perfil Adicional
  rut             String?   @db.VarChar(20)
  phone           String?   @db.VarChar(20)
  birthDate       DateTime? @map("birth_date") @db.Date
  position        String?   @db.VarChar(100)
  
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relaciones
  tenantId        String?   @map("tenant_id") @db.Uuid
  tenant          Tenant?   @relation(fields: [tenantId], references: [id])
  siteAccess      UserSite[]

  @@unique([tenantId, rut])
  @@map("users")
}

model Tenant {
  id              String    @id @default(uuid()) @db.Uuid
  code            String    @unique @db.VarChar(20) // Ej: TPM, BAR-01
  name            String    @db.VarChar(100)
  
  // Datos
  rut             String?   @db.VarChar(20)
  address         String?   @db.VarChar(255)
  phone           String?   @db.VarChar(20)

  // Marca
  logoUrl         String?   @map("logo_url") @db.VarChar(255)
  primaryColor    String    @default("#FF3366") @map("primary_color") @db.VarChar(50)
  backgroundPreference BackgroundPreference @default(DARK) @map("background_preference")

  isActive        Boolean   @default(true) @map("is_active")
  
  sites           Site[]
  users           User[]
  equipments      Equipment[]
  workOrders      WorkOrder[]
  catalogs        CatalogItem[]
  
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@map("tenants")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  SUPERVISOR
  MECHANIC
}

enum BackgroundPreference {
  DARK
  LIGHT
}

// ==========================================
// 6. FAENAS Y PROYECTOS (SITES)
// ==========================================
model Site {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  code        String   @db.VarChar(20) // Ej: FAE-NORTE, PROY-01
  name        String   @db.VarChar(100)
  isActive    Boolean  @default(true) @map("is_active")

  // Relaciones
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users       UserSite[]
  equipments  Equipment[]
  workOrders  WorkOrder[]

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, code])
  @@map("sites")
}

// Tabla intermedia para asignar usuarios a múltiples faenas (si es necesario)
model UserSite {
  userId      String @map("user_id") @db.Uuid
  siteId      String @map("site_id") @db.Uuid

  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  site        Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@id([userId, siteId])
  @@map("user_sites")
}