# Base de Datos
DATABASE_URL="postgresql://erp_admin:supersecretpassword@db:5432/erp_database?schema=public"

# Servidor
PORT=3000

# Seguridad
JWT_SECRET="CAMBIAR_ESTO_EN_PRODUCCION"

# Frontend Link (CORS) - Debe coincidir exactamente con el origen del frontend
FRONTEND_URL="https://app.baselogic.cl"

# Web Push (VAPID) — Generar con: npx web-push generate-vapid-keys
# El front debe usar solo VAPID_PUBLIC_KEY para suscribirse.
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
# Contacto del remitente (RFC 8292), p. ej. mailto del equipo
VAPID_SUBJECT="mailto:notificaciones@baselogic.cl"

# Mailer (Ethereal Dev / SMTP real)
SMTP_HOST="smtp.xxxx.com"
SMTP_PORT=587
SMTP_USER="user@xxxx.com"
SMTP_PASS="password"
